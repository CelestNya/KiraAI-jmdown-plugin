{
    "max_cache": {
        "type": "integer",
        "default": 10,
        "hint": "最多缓存几本 PDF，超限自动删最旧"
    },
    "desc_max_length": {
        "type": "integer",
        "default": 80,
        "hint": "描述截取字符数"
    },
    "download_threads": {
        "type": "integer",
        "default": 45,
        "hint": "下载图片的并行线程数"
    },
    "upload_timeout": {
        "type": "integer",
        "default": 300,
        "hint": "上传超时秒数（大文件建议 300+）"
    },
    "notify_llm": {
        "type": "switch",
        "default": true,
        "hint": "任务完成后是否在目标会话触发 LLM 自动回复"
    }
}
