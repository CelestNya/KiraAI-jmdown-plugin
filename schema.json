{
    "max_cache": {
        "type": "integer",
        "default": 10,
        "hint": "最多缓存几本 PDF，超限自动删最旧"
    },
    "desc_max_length": {
        "type": "integer",
        "default": 80,
        "hint": "描述截取字符数"
    },
    "download_threads": {
        "type": "integer",
        "default": 45,
        "hint": "下载图片的并行线程数"
    },
    "stream_threshold_mb": {
        "type": "integer",
        "default": 10,
        "hint": "超过此 MB 的 PDF 走流传输，避免 WebSocket 帧超限"
    },
    "upload_timeout": {
        "type": "integer",
        "default": 300,
        "hint": "上传超时秒数（大文件建议 300+）"
    }
}
